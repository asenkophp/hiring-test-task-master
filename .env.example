APP_NAME="E-Commerce Admin"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ecommerce
DB_USERNAME=ecom
DB_PASSWORD=secret

BROADCAST_CONNECTION=reverb
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Default admin credentials seeded by DatabaseSeeder
ADMIN_EMAIL=dev@test.com
ADMIN_PASSWORD=password

# Telegram Bot — operator notifications on new orders
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# External payment gateway (mock during local dev)
PAYMENT_GATEWAY_URL=http://payment-mock.local/api
PAYMENT_GATEWAY_KEY=test_key_local

# Reverb (WebSocket server)
REVERB_APP_ID=local
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

HORIZON_PREFIX=horizon-ecom:
